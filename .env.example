# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_RETRY_ATTEMPTS=5
MONGO_RETRY_DELAY=3000

# ==========================================
# JWT CONFIGURATION
# ==========================================
ACCESS_TOKEN_SECRET=your_secret_key_for_access_tokens_min_32_chars
REFRESH_TOKEN_SECRET=your_secret_key_for_refresh_tokens_min_32_chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ==========================================
# SESSION CONFIGURATION
# ==========================================
SESSION_SECRET=your_session_secret_key_min_32_characters_long

# ==========================================
# GOOGLE OAUTH (Optional)
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ==========================================
# AI & GEMINI CONFIGURATION
# ==========================================
GEMINI_API_KEY=your_gemini_api_key

# ==========================================
# WEB PUSH NOTIFICATIONS (Optional)
# ==========================================
VAPID_EMAIL=your_email@example.com
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
VITE_API_URL=http://localhost:3000/api
FRONTEND_URL=http://localhost:5173

# ==========================================
# LOGGING & MONITORING
# ==========================================
LOG_LEVEL=debug
DEBUG=false

# ==========================================
# CORS CONFIGURATION
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
